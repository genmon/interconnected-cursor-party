# REQUIRED: Your Cloudflare Worker hostname (without https://)
# This is where the WebSocket connection will be made
# Critical for production builds when script is embedded on other sites
WORKER_HOST=cursor-party.YOUR-ACCOUNT.workers.dev

# Website allowlist - JSON array of URL patterns
# For local dev, use .dev.vars instead
# Make sure to include your worker URL in the allowlist!
WEBSITES=["https://cursor-party.YOUR-ACCOUNT.workers.dev/*", "https://(www.)?interconnected.org/*"]
